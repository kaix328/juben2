    "backup": "powershell -ExecutionPolicy Bypass -File scripts/backup.ps1",
    "clean-cache": "node scripts/clean-cache.cjs",
    "diagnose": "node scripts/diagnose-project.cjs",
    "fix": "node scripts/fix-common-issues.cjs",
    "verify": "node scripts/verify-deployment.cjs",
    "verify:quick": "node scripts/verify-deployment.cjs --skip-tests --skip-build"
  },
